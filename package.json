{
  "name": "@raycas96/nanostorage",
  "version": "0.0.1",
  "description": "Tiny, zero-dependency localStorage/sessionStorage sync for same-tab and cross-tab updates.",
  "license": "MIT",
  "author": "raycas96",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raycas96/nanostorage.git"
  },
  "bugs": {
    "url": "https://github.com/Raycas96/nanostorage/issues"
  },
  "homepage": "https://github.com/Raycas96/nanostorage#readme",
  "type": "module",
  "main": "./dist/core/index.cjs",
  "module": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "storage",
    "localstorage",
    "sessionstorage",
    "broadcastchannel",
    "sync",
    "react"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome check . --write",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
