{
	"name": "@raycas/nanostorage",
	"version": "0.1.0-beta.3",
	"description": "Tiny, zero-dependency localStorage/sessionStorage sync for same-tab and cross-tab updates.",
	"license": "MIT",
	"author": "raycas96",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Raycas96/nanostorage.git"
	},
	"bugs": {
		"url": "https://github.com/Raycas96/nanostorage/issues"
	},
	"homepage": "https://github.com/Raycas96/nanostorage#readme",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"type": "module",
	"main": "./dist/core/index.cjs",
	"module": "./dist/core/index.mjs",
	"types": "./dist/core/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/core/index.d.mts",
			"import": "./dist/core/index.mjs",
			"require": "./dist/core/index.cjs"
		},
		"./core": {
			"types": "./dist/core/index.d.mts",
			"import": "./dist/core/index.mjs",
			"require": "./dist/core/index.cjs"
		},
		"./react": {
			"types": "./dist/react/index.d.mts",
			"import": "./dist/react/index.mjs",
			"require": "./dist/react/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"keywords": [
		"storage",
		"localstorage",
		"sessionstorage",
		"broadcastchannel",
		"sync",
		"react"
	],
	"engines": {
		"node": ">=18.20.8"
	},
	"scripts": {
		"build": "tsdown",
		"build:size": "tsdown --config tsdown.size.config.ts",
		"dev": "tsdown --watch",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "npm run test:unit && npm run test:e2e",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"size:core": "gzip -c dist/core/index.mjs | wc -c",
		"size:react": "gzip -c dist/react/index.mjs | wc -c",
		"size:check": "bundlesize",
		"size": "npm run build:size && npm run size:core && npm run size:react && npm run size:check",
		"release": "changeset publish",
		"prepare": "husky"
	},
	"bundlesize": [
		{
			"path": "./dist/core/index.mjs",
			"maxSize": "1 kB"
		},
		{
			"path": "./dist/react/index.mjs",
			"maxSize": "2 kB"
		}
	],
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.59.1",
		"@types/node": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bundlesize": "^0.18.2",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
